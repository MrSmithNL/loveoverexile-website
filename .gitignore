# Claude Code — ignore machine-specific state, keep rules
.claude/*
!.claude/rules/

# Secrets and credentials — NEVER commit these
.env
.env.*
*.key
*.pem

# macOS system files
.DS_Store
.AppleDouble
.LSOverrideIcon

# VS Code workspace settings (machine-specific)
.vscode/

# Temporary files
*.tmp
*.log
backups/

# MkDocs build output
site/
encryptcontent.cache
