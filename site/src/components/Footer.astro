---
const currentYear = new Date().getFullYear();

const footerLinks = {
  'The Platform': [
    { label: 'Home',               href: '/' },
    { label: 'The Book',           href: '/the-book' },
    { label: 'About the Author',   href: '/about' },
    { label: 'Articles',           href: '/articles' },
    { label: 'Community',          href: '/community' },
  ],
  'Content': [
    { label: 'Understanding PA',   href: '/understanding' },
    { label: 'Survival Guide',     href: '/survival-guide' },
    { label: 'Inner Freedom',      href: '/inner-freedom' },
    { label: 'You Are Not Alone',  href: '/you-are-not-alone' },
    { label: 'Start Here',         href: '/start-here' },
  ],
  'Support': [
    { label: 'Free Guide',         href: '/free-guide' },
    { label: 'Resources',          href: '/resources' },
    { label: 'FAQ',                href: '/faq' },
    { label: 'Contact',            href: '/contact' },
    { label: 'Privacy Policy',     href: '/privacy-policy' },
  ],
};

const socialLinks = [
  {
    label: 'Instagram',
    href:  'https://www.instagram.com/loveoverexile',
    icon:  `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>`,
  },
  {
    label: 'LinkedIn',
    href:  'https://www.linkedin.com/in/malcolm-smith-loveoverexile',
    icon:  `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>`,
  },
];
---

<footer class="site-footer">
  <div class="container">

    <!-- Top row: brand + columns -->
    <div class="footer-top">
      <!-- Brand -->
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          <img src="/images/logo.png" alt="" class="footer-logo-img" width="40" height="40" />
          Love Over Exile
        </a>
        <p class="footer-tagline">
          A book, a community, and a pathway through parental alienation —
          for parents who refuse to give up.
        </p>
        <div class="footer-social">
          {socialLinks.map(link => (
            <a
              href={link.href}
              class="social-link"
              aria-label={link.label}
              target="_blank"
              rel="noopener noreferrer"
              set:html={link.icon}
            />
          ))}
        </div>
      </div>

      <!-- Link columns -->
      {Object.entries(footerLinks).map(([heading, links]) => (
        <div class="footer-col">
          <h4 class="footer-col-heading">{heading}</h4>
          <ul role="list">
            {links.map(link => (
              <li><a href={link.href} class="footer-link">{link.label}</a></li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Divider -->
    <hr class="footer-divider" />

    <!-- Bottom row: legal -->
    <div class="footer-bottom">
      <p>&copy; {currentYear} Love Over Exile · Malcolm Smith. All rights reserved.</p>
      <p>
        <a href="/privacy-policy" class="footer-link">Privacy Policy</a>
        &nbsp;·&nbsp;
        <a href="/contact" class="footer-link">Contact</a>
      </p>
    </div>

  </div>
</footer>

<style>
.site-footer {
  background-color: var(--color-green-dark);
  color: rgba(247, 243, 238, 0.75);
  padding-block: 4rem 2rem;
  margin-top: auto;
}

.footer-top {
  display: grid;
  grid-template-columns: 1.8fr 1fr 1fr 1fr;
  gap: 3rem;
  margin-bottom: 3rem;
}

.footer-brand {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.footer-logo {
  font-family: var(--font-serif);
  font-size: 1.3rem;
  font-weight: 600;
  color: var(--color-ivory);
  text-decoration: none;
  letter-spacing: -0.01em;
  display: flex;
  align-items: center;
  gap: 0.65rem;
}
.footer-logo-img {
  height: 40px;
  width: auto;
  display: block;
  flex-shrink: 0;
}
.footer-logo:hover { color: var(--color-amber-light); }

.footer-tagline {
  font-size: 0.88rem;
  line-height: 1.65;
  color: rgba(247, 243, 238, 0.65);
  margin: 0;
  max-width: 280px;
}

.footer-social {
  display: flex;
  gap: 0.75rem;
  margin-top: 0.5rem;
}
.social-link {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 38px;
  height: 38px;
  border-radius: 8px;
  border: 1px solid rgba(247, 243, 238, 0.2);
  color: rgba(247, 243, 238, 0.7);
  transition: color 0.2s, border-color 0.2s, background 0.2s;
}
.social-link:hover {
  color: var(--color-ivory);
  border-color: var(--color-amber);
  background: rgba(208, 57, 26, 0.12);
}

.footer-col h4,
.footer-col-heading {
  font-family: var(--font-sans);
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--color-ivory);
  margin: 0 0 1rem;
}

.footer-col ul {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.footer-link {
  font-size: 0.88rem;
  color: rgba(247, 243, 238, 0.65);
  text-decoration: none;
  transition: color 0.15s;
}
.footer-link:hover { color: var(--color-ivory); }

.footer-divider {
  border: none;
  border-top: 1px solid rgba(247, 243, 238, 0.12);
  margin: 0 0 1.5rem;
}

.footer-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 1rem;
  flex-wrap: wrap;
}
.footer-bottom p {
  font-size: 0.82rem;
  color: rgba(247, 243, 238, 0.45);
  margin: 0;
}

@media (max-width: 900px) {
  .footer-top {
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }
  .footer-brand {
    grid-column: 1 / -1;
  }
  .footer-tagline { max-width: none; }
}

@media (max-width: 600px) {
  .footer-top {
    grid-template-columns: 1fr;
  }
  .footer-bottom {
    flex-direction: column;
    align-items: flex-start;
  }
}
</style>
