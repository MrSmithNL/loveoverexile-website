---
interface NavChild {
  label: string;
  href: string;
  highlight?: boolean;
  separator?: boolean;
}
interface NavItem {
  label: string;
  href?: string;
  children?: NavChild[];
}

const navItems: NavItem[] = [
  {
    label: 'Parental Alienation',
    children: [
      { label: 'Start Here',                  href: '/start-here', highlight: true },
      { label: 'What Is Parental Alienation',  href: '/understanding' },
      { label: 'You Are Not Alone',            href: '/you-are-not-alone' },
      { label: 'How to Recognise It',          href: '/articles/signs-of-parental-alienation', separator: true },
      { label: 'The Alienating Parent',        href: '/understanding/the-alienating-parent' },
      { label: 'The Child',                    href: '/understanding/the-child' },
      { label: 'The Alienated Parent',         href: '/understanding/the-alienated-parent' },
      { label: 'Affected Family & Friends',    href: '/understanding/affected-family' },
      { label: 'Institutions & the System',    href: '/understanding/institutions' },
    ],
  },
  {
    label: 'Survival Guide',
    children: [
      { label: 'Download the Free Guide',      href: '/free-guide', highlight: true, separator: true },
      { label: 'Health & Safety First',         href: '/survival-guide/health-and-safety' },
      { label: 'Building Your Support Team',    href: '/survival-guide/support-team' },
      { label: 'Communication Strategies',      href: '/survival-guide/communication' },
      { label: 'Staying Connected to Your Child', href: '/survival-guide/staying-connected' },
      { label: 'Avoiding the Traps',            href: '/survival-guide/avoiding-the-traps' },
      { label: 'The Long Game',                 href: '/survival-guide/the-long-game' },
    ],
  },
  {
    label: 'Inner Freedom',
    children: [
      { label: 'Finding Inner Freedom',         href: '/inner-freedom' },
      { label: 'Radical Acceptance',             href: '/inner-freedom/radical-acceptance' },
      { label: 'Finding Meaning',                href: '/inner-freedom/finding-meaning' },
      { label: 'Ambiguous Loss & Grief',         href: '/inner-freedom/ambiguous-loss' },
      { label: 'Rebuilding Your Identity',       href: '/inner-freedom/rebuilding-identity' },
      { label: 'Unconditional Love',             href: '/inner-freedom/unconditional-love' },
    ],
  },
  {
    label: 'Resources',
    children: [
      { label: 'Community Forum',               href: '/community' },
      { label: 'Articles',                       href: '/articles' },
      { label: 'Books & Reading List',           href: '/resources' },
      { label: 'FAQ',                            href: '/faq' },
      { label: 'Contact',                        href: '/contact' },
    ],
  },
  {
    label: 'The Book',
    children: [
      { label: 'About Love Over Exile',          href: '/the-book' },
      { label: "Malcolm's Story",                href: '/about' },
    ],
  },
];

const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);
const isParentActive = (item: NavItem) =>
  item.children?.some(child => isActive(child.href)) ?? false;
---

<header class="site-header">
  <div class="container">
    <nav class="nav-inner" aria-label="Main navigation">
      <!-- Logo -->
      <a href="/" class="logo" aria-label="Love Over Exile — Home">
        <img src="/images/logo.png" alt="" class="logo-img" width="38" height="38" />
        <span class="logo-text">Love Over Exile</span>
      </a>

      <!-- Desktop links -->
      <ul class="nav-links" role="list">
        {navItems.map(item => (
          <li class="nav-item" data-dropdown>
            {item.children ? (
              <>
                <button
                  class={`nav-link nav-link--parent ${isParentActive(item) ? 'nav-link--active' : ''}`}
                  aria-expanded="false"
                  type="button"
                >
                  {item.label}
                  <svg class="nav-chevron" width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true">
                    <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </button>
                <div class="dropdown">
                  <ul role="list" class="dropdown-list">
                    {item.children.map(child => (
                      <li class={child.separator ? 'dropdown-separator' : ''}>
                        <a
                          href={child.href}
                          class:list={[
                            'dropdown-link',
                            isActive(child.href) && 'dropdown-link--active',
                            child.highlight && 'dropdown-link--highlight',
                          ]}
                          aria-current={isActive(child.href) ? 'page' : undefined}
                        >
                          {child.highlight && (
                            <svg class="dropdown-link-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                              <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
                            </svg>
                          )}
                          {child.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              </>
            ) : (
              <a
                href={item.href}
                class={`nav-link ${isActive(item.href!) ? 'nav-link--active' : ''}`}
                aria-current={isActive(item.href!) ? 'page' : undefined}
              >
                {item.label}
              </a>
            )}
          </li>
        ))}
      </ul>

      <!-- CTA -->
      <a href="/free-guide" class="btn btn-primary nav-cta">
        Get the Free Guide
      </a>

      <!-- Mobile hamburger -->
      <button class="hamburger" id="menu-toggle" aria-expanded="false" aria-controls="mobile-menu" aria-label="Open menu">
        <span></span><span></span><span></span>
      </button>
    </nav>
  </div>

  <!-- Mobile menu -->
  <div class="mobile-menu" id="mobile-menu" role="dialog" aria-label="Mobile navigation">
    <ul role="list" class="mobile-nav-list">
      {navItems.map(item => (
        <li class="mobile-nav-group">
          {item.children ? (
            <>
              <button
                class={`mobile-nav-heading ${isParentActive(item) ? 'mobile-nav-heading--active' : ''}`}
                aria-expanded="false"
                type="button"
              >
                {item.label}
                <svg class="mobile-chevron" width="12" height="7" viewBox="0 0 12 7" fill="none" aria-hidden="true">
                  <path d="M1 1l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
              <ul role="list" class="mobile-subnav">
                {item.children.map(child => (
                  <li class={child.separator ? 'mobile-separator' : ''}>
                    <a
                      href={child.href}
                      class:list={[
                        'mobile-nav-link',
                        isActive(child.href) && 'mobile-nav-link--active',
                        child.highlight && 'mobile-nav-link--highlight',
                      ]}
                    >
                      {child.highlight && (
                        <svg class="mobile-link-icon" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
                        </svg>
                      )}
                      {child.label}
                    </a>
                  </li>
                ))}
              </ul>
            </>
          ) : (
            <a
              href={item.href}
              class={`mobile-nav-heading mobile-nav-heading--link ${isActive(item.href!) ? 'mobile-nav-heading--active' : ''}`}
            >
              {item.label}
            </a>
          )}
        </li>
      ))}
      <li class="mobile-nav-cta">
        <a href="/free-guide" class="btn btn-primary" style="width: 100%; justify-content: center;">
          Get the Free Guide
        </a>
      </li>
    </ul>
  </div>
</header>

<style>
/* ───── Header ───── */
.site-header {
  position: sticky;
  top: 0;
  z-index: 100;
  background: var(--color-ivory);
  border-bottom: 1px solid var(--color-border);
  backdrop-filter: blur(8px);
}

.nav-inner {
  display: flex;
  align-items: center;
  gap: 1.5rem;
  height: 68px;
}

/* ───── Logo ───── */
.logo {
  flex-shrink: 0;
  text-decoration: none;
  display: flex;
  align-items: center;
  gap: 0.6rem;
}
.logo-img {
  height: 38px;
  width: auto;
  display: block;
}
.logo-text {
  font-family: var(--font-serif);
  font-size: 1.2rem;
  font-weight: 600;
  color: var(--color-green-deep);
  letter-spacing: -0.01em;
  white-space: nowrap;
}

/* ───── Desktop nav links ───── */
.nav-links {
  display: flex;
  align-items: center;
  gap: 0.15rem;
  list-style: none;
  margin: 0;
  padding: 0;
  flex: 1;
}

.nav-item {
  position: relative;
}

.nav-link {
  display: flex;
  align-items: center;
  gap: 0.3rem;
  padding: 0.4rem 0.65rem;
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--color-charcoal);
  text-decoration: none;
  border-radius: 5px;
  transition: color 0.15s, background 0.15s;
  white-space: nowrap;
  border: none;
  background: none;
  cursor: pointer;
  font-family: inherit;
}
.nav-link:hover {
  color: var(--color-green-deep);
  background: rgba(38, 120, 142, 0.06);
}
.nav-link--active {
  color: var(--color-green-deep);
  font-weight: 600;
}

.nav-chevron {
  flex-shrink: 0;
  transition: transform 0.2s;
}

/* ───── Desktop dropdown ───── */
.dropdown {
  position: absolute;
  top: 100%;
  left: 50%;
  min-width: 280px;
  width: max-content;
  max-width: 340px;
  background: var(--color-ivory);
  border: 1px solid var(--color-border);
  border-radius: 10px;
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1), 0 2px 6px rgba(0, 0, 0, 0.05);
  padding: 0.5rem;
  opacity: 0;
  visibility: hidden;
  transform: translateX(-50%) translateY(4px);
  transition: opacity 0.18s ease, visibility 0.18s, transform 0.18s ease;
  pointer-events: none;
}

/* Invisible bridge: fills the gap between nav button and dropdown
   so the mouse doesn't lose hover when moving down */
.dropdown::before {
  content: '';
  position: absolute;
  top: -12px;
  left: 0;
  right: 0;
  height: 12px;
}

/* Show dropdown — controlled by JS via .is-open class */
.nav-item.is-open > .dropdown {
  opacity: 1;
  visibility: visible;
  transform: translateX(-50%) translateY(0);
  pointer-events: auto;
}

.nav-item.is-open > .nav-link--parent .nav-chevron {
  transform: rotate(180deg);
}

.dropdown-list {
  list-style: none;
  margin: 0;
  padding: 0;
}

/* Separator: adds a subtle divider line after an item */
.dropdown-separator {
  padding-bottom: 0.35rem;
  margin-bottom: 0.35rem;
  border-bottom: 1px solid var(--color-border);
}

.dropdown-link {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  padding: 0.55rem 0.85rem;
  font-size: 0.875rem;
  font-weight: 450;
  color: var(--color-charcoal);
  text-decoration: none;
  border-radius: 6px;
  transition: color 0.12s, background 0.12s;
  line-height: 1.3;
  white-space: nowrap;
}
.dropdown-link:hover {
  color: var(--color-green-deep);
  background: rgba(38, 120, 142, 0.06);
}
.dropdown-link--active {
  color: var(--color-green-deep);
  font-weight: 600;
}

/* Highlighted menu item — stands out with amber accent */
.dropdown-link--highlight {
  color: var(--color-amber-dark, #631B08);
  font-weight: 600;
}
.dropdown-link--highlight:hover {
  color: var(--color-amber-dark, #631B08);
  background: rgba(226, 72, 12, 0.08);
}

.dropdown-link-icon {
  flex-shrink: 0;
  color: var(--color-amber, #E2480C);
}

/* ───── CTA ───── */
.nav-cta {
  flex-shrink: 0;
  font-size: 0.85rem;
  padding: 0.55rem 1.1rem;
}

/* ───── Hamburger ───── */
.hamburger {
  display: none;
  flex-direction: column;
  gap: 5px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 6px;
  margin-left: auto;
}
.hamburger span {
  display: block;
  width: 24px;
  height: 2px;
  background: var(--color-green-deep);
  border-radius: 2px;
  transition: all 0.25s;
}
.hamburger[aria-expanded="true"] span:nth-child(1) {
  transform: rotate(45deg) translate(5px, 5px);
}
.hamburger[aria-expanded="true"] span:nth-child(2) {
  opacity: 0;
}
.hamburger[aria-expanded="true"] span:nth-child(3) {
  transform: rotate(-45deg) translate(5px, -5px);
}

/* ───── Mobile menu ───── */
.mobile-menu {
  display: none;
  padding: 1rem 1.5rem 1.5rem;
  border-top: 1px solid var(--color-border);
  background: var(--color-ivory);
  max-height: calc(100vh - 68px);
  overflow-y: auto;
}
.mobile-menu.is-open {
  display: block;
}

.mobile-nav-list {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
}

.mobile-nav-group {
  border-bottom: 1px solid var(--color-border);
  padding-bottom: 0.25rem;
  margin-bottom: 0.25rem;
}
.mobile-nav-group:last-of-type {
  border-bottom: none;
}

.mobile-nav-heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  padding: 0.75rem 0.75rem;
  font-size: 0.95rem;
  font-weight: 600;
  color: var(--color-green-deep);
  text-decoration: none;
  border: none;
  background: none;
  cursor: pointer;
  font-family: inherit;
  border-radius: 6px;
  transition: background 0.15s;
}
.mobile-nav-heading:hover {
  background: rgba(38, 120, 142, 0.06);
}
.mobile-nav-heading--active {
  color: var(--color-green-deep);
}

.mobile-chevron {
  flex-shrink: 0;
  transition: transform 0.25s;
}
.mobile-nav-heading[aria-expanded="true"] .mobile-chevron {
  transform: rotate(180deg);
}

.mobile-subnav {
  list-style: none;
  margin: 0;
  padding: 0 0 0.5rem;
  display: none;
}
.mobile-nav-heading[aria-expanded="true"] + .mobile-subnav {
  display: block;
}

.mobile-separator {
  padding-bottom: 0.35rem;
  margin-bottom: 0.35rem;
  border-bottom: 1px solid var(--color-border);
}

.mobile-nav-link {
  display: flex;
  align-items: center;
  gap: 0.35rem;
  padding: 0.5rem 0.75rem 0.5rem 1.5rem;
  font-size: 0.9rem;
  font-weight: 450;
  color: var(--color-charcoal);
  text-decoration: none;
  border-radius: 6px;
  transition: background 0.12s, color 0.12s;
}
.mobile-nav-link:hover,
.mobile-nav-link--active {
  background: rgba(38, 120, 142, 0.06);
  color: var(--color-green-deep);
}

/* Highlighted item in mobile */
.mobile-nav-link--highlight {
  color: var(--color-amber-dark, #631B08);
  font-weight: 600;
}
.mobile-nav-link--highlight:hover {
  background: rgba(226, 72, 12, 0.08);
  color: var(--color-amber-dark, #631B08);
}

.mobile-link-icon {
  flex-shrink: 0;
  color: var(--color-amber, #E2480C);
}

.mobile-nav-cta {
  padding-top: 0.75rem;
}

/* ───── Responsive ───── */
@media (max-width: 1024px) {
  .nav-links, .nav-cta { display: none; }
  .hamburger { display: flex; }
}
</style>

<script>
// ── Desktop dropdown with hover intent (delay before closing) ──
const OPEN_DELAY = 80;
const CLOSE_DELAY = 300;

document.querySelectorAll<HTMLElement>('[data-dropdown]').forEach(item => {
  let openTimer: ReturnType<typeof setTimeout> | null = null;
  let closeTimer: ReturnType<typeof setTimeout> | null = null;

  const open = () => {
    if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; }
    openTimer = setTimeout(() => {
      // Close any other open dropdowns
      document.querySelectorAll<HTMLElement>('[data-dropdown].is-open').forEach(other => {
        if (other !== item) other.classList.remove('is-open');
      });
      item.classList.add('is-open');
    }, OPEN_DELAY);
  };

  const close = () => {
    if (openTimer) { clearTimeout(openTimer); openTimer = null; }
    closeTimer = setTimeout(() => {
      item.classList.remove('is-open');
    }, CLOSE_DELAY);
  };

  item.addEventListener('mouseenter', open);
  item.addEventListener('mouseleave', close);

  // Also handle click on the parent button (for touch/keyboard)
  const btn = item.querySelector('.nav-link--parent');
  btn?.addEventListener('click', () => {
    const isOpen = item.classList.contains('is-open');
    document.querySelectorAll<HTMLElement>('[data-dropdown].is-open').forEach(other => {
      other.classList.remove('is-open');
    });
    if (!isOpen) item.classList.add('is-open');
  });

  // Keep dropdown open while focus is inside (keyboard nav)
  item.addEventListener('focusin', open);
  item.addEventListener('focusout', (e) => {
    const related = (e as FocusEvent).relatedTarget as HTMLElement | null;
    if (!item.contains(related)) close();
  });
});

// Close all dropdowns when clicking outside
document.addEventListener('click', (e) => {
  const target = e.target as HTMLElement;
  if (!target.closest('[data-dropdown]')) {
    document.querySelectorAll<HTMLElement>('[data-dropdown].is-open').forEach(item => {
      item.classList.remove('is-open');
    });
  }
});

// Close on Escape
document.addEventListener('keydown', (e) => {
  if (e.key === 'Escape') {
    document.querySelectorAll<HTMLElement>('[data-dropdown].is-open').forEach(item => {
      item.classList.remove('is-open');
    });
  }
});

// ── Mobile menu toggle ──
const toggle = document.getElementById('menu-toggle');
const menu = document.getElementById('mobile-menu');
toggle?.addEventListener('click', () => {
  const open = menu?.classList.toggle('is-open');
  toggle.setAttribute('aria-expanded', String(!!open));
});

// ── Mobile accordion toggles ──
document.querySelectorAll('.mobile-nav-heading:not(.mobile-nav-heading--link)').forEach(btn => {
  btn.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    document.querySelectorAll('.mobile-nav-heading:not(.mobile-nav-heading--link)').forEach(other => {
      if (other !== btn) other.setAttribute('aria-expanded', 'false');
    });
    btn.setAttribute('aria-expanded', String(!expanded));
  });
});
</script>
