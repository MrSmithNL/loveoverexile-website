---
import BaseLayout from '../../layouts/BaseLayout.astro';

// Articles — will eventually be replaced by CMS data
const articles = [
  {
    slug: 'signs-of-parental-alienation',
    title: 'Signs of Parental Alienation: What to Look For and What It Means',
    excerpt: 'The patterns that indicate deliberate alienation versus normal post-separation conflict — and why distinguishing them matters for your strategy.',
    category: 'Understanding PA',
    date: '2026-03-02',
    readTime: '8 min',
  },
  {
    slug: 'how-to-cope-with-parental-alienation',
    title: 'How to Cope With Parental Alienation: A Framework for the Acute Phase',
    excerpt: 'When you are in the middle of it, the world feels like it is collapsing. Here is a structure that has helped parents survive the worst periods.',
    category: 'Survival Guide',
    date: '2026-03-02',
    readTime: '12 min',
  },
  {
    slug: 'choosing-love-over-exile',
    title: 'Choosing Love Over Exile: What It Actually Means to Stay Present',
    excerpt: '"Staying present" sounds like a platitude until you understand what it requires — and what it gives back.',
    category: 'Inner Freedom',
    date: '2026-03-02',
    readTime: '10 min',
  },
];

const categories = ['All', 'Understanding PA', 'Survival Guide', 'Inner Freedom'];
---

<BaseLayout
  title="Articles"
  description="Articles on parental alienation — understanding it, surviving it, and finding inner freedom. Written by Malcolm Smith, author of Love Over Exile."
>

  <section class="section">
    <div class="container">
      <div class="articles-header">
        <p class="eyebrow">Writing</p>
        <h1>Articles</h1>
        <p class="articles-intro">
          Long-form articles on parental alienation — evidence-based, personal, and practical.
          Written to give you what most resources don't: the full picture.
        </p>
      </div>

      <!-- Category filters -->
      <div class="category-filters" role="navigation" aria-label="Article categories">
        {categories.map(cat => (
          <a
            href={cat === 'All' ? '/articles' : `/articles#${cat.toLowerCase().replace(/ /g, '-')}`}
            class={`filter-btn ${cat === 'All' ? 'filter-btn--active' : ''}`}
          >
            {cat}
          </a>
        ))}
      </div>

      <!-- Articles list -->
      <div class="articles-list">
        {articles.map(article => (
          <article class="article-row">
            <div class="article-row-meta">
              <span class="article-tag">{article.category}</span>
              <time datetime={article.date} class="article-date">
                {new Date(article.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
              </time>
              <span class="article-read-time">{article.readTime} read</span>
            </div>
            <h2 class="article-row-title">
              <a href={`/articles/${article.slug}`}>{article.title}</a>
            </h2>
            <p class="article-row-excerpt">{article.excerpt}</p>
            <a href={`/articles/${article.slug}`} class="article-row-link">Read the article →</a>
          </article>
        ))}
      </div>

    </div>
  </section>

</BaseLayout>

<style>
.articles-header { max-width: 660px; margin-bottom: 3rem; }
.eyebrow {
  font-size: 0.78rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--color-amber);
  margin-bottom: 0.5rem;
}
.articles-intro {
  font-size: 1.05rem;
  color: var(--color-charcoal-mid);
  line-height: 1.7;
  margin-top: 0.75rem;
}

.category-filters {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
  margin-bottom: 3rem;
}
.filter-btn {
  padding: 0.4rem 1rem;
  border-radius: 20px;
  font-size: 0.85rem;
  font-weight: 500;
  border: 1.5px solid var(--color-border);
  color: var(--color-charcoal-mid);
  text-decoration: none;
  transition: all 0.15s;
}
.filter-btn:hover,
.filter-btn--active {
  background: var(--color-green-deep);
  border-color: var(--color-green-deep);
  color: var(--color-ivory);
}

.articles-list {
  display: flex;
  flex-direction: column;
  gap: 0;
}
.article-row {
  padding-block: 2.5rem;
  border-bottom: 1px solid var(--color-border);
}
.article-row:first-child { border-top: 1px solid var(--color-border); }

.article-row-meta {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-bottom: 0.75rem;
  flex-wrap: wrap;
}
.article-tag {
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--color-amber);
  background: rgba(196,154,60,0.1);
  border-radius: 4px;
  padding: 0.2em 0.6em;
}
.article-date,
.article-read-time {
  font-size: 0.82rem;
  color: var(--color-warm-grey);
}
.article-date::after { content: '·'; margin-left: 0.75rem; }

.article-row-title {
  font-size: clamp(1.2rem, 2.5vw, 1.5rem);
  margin-bottom: 0.75rem;
  line-height: 1.3;
}
.article-row-title a {
  color: var(--color-green-deep);
  text-decoration: none;
  transition: color 0.15s;
}
.article-row-title a:hover { color: var(--color-amber); }

.article-row-excerpt {
  font-size: 0.95rem;
  color: var(--color-charcoal-mid);
  line-height: 1.7;
  max-width: 680px;
  margin-bottom: 1rem;
}
.article-row-link {
  font-size: 0.88rem;
  font-weight: 600;
  color: var(--color-amber);
  text-decoration: none;
  transition: color 0.15s;
}
.article-row-link:hover { color: var(--color-green-deep); }
</style>
