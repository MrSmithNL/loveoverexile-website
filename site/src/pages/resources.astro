---
import BaseLayout from '../layouts/BaseLayout.astro';
import { resources, categoryLabels } from '../data/resources';

const crisisResources = resources.filter(r => r.category === 'crisis');
const mainResources   = resources.filter(r => r.category !== 'crisis');

const categories = Object.entries(categoryLabels).filter(([key]) => key !== 'crisis');

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Resources for Alienated Parents',
  description: 'Curated books, organisations, research, and support resources for parents experiencing parental alienation.',
  numberOfItems: resources.length,
  itemListElement: resources.map((r, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': r.url ? 'WebPage' : 'CreativeWork',
      name: r.title,
      ...(r.url && { url: r.url }),
      ...(r.author && { author: { '@type': 'Person', name: r.author } }),
      description: r.description,
    },
  })),
};
---

<BaseLayout
  title="Resources for Alienated Parents"
  description="Curated books, organisations, research, and crisis support for alienated parents. Over 50 resources referenced in Love Over Exile by Malcolm Smith."
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />

  <section class="section">
    <div class="container-narrow">
      <p class="eyebrow">Resources</p>
      <h1>Resources for Alienated Parents</h1>
      <p class="intro">
        Over 50 curated resources — books, organisations, research studies, and crisis support —
        drawn from the references in <em>Love Over Exile</em> and expanded with community recommendations.
      </p>

      <!-- Crisis banner — always visible -->
      <div class="crisis-banner">
        <h2 class="crisis-heading">Need immediate support?</h2>
        <div class="crisis-items">
          {crisisResources.map(r => (
            <div class="crisis-item">
              <a href={r.url} target="_blank" rel="noopener noreferrer" class="crisis-title">{r.title}</a>
              {r.phone && <span class="crisis-phone">{r.phone}</span>}
              <p class="crisis-note">{r.description}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Search + filters -->
      <div class="filter-bar">
        <div class="search-wrap">
          <input
            type="text"
            id="resource-search"
            placeholder="Search by title, author, or keyword…"
            class="search-input"
            autocomplete="off"
          />
        </div>
        <div class="filter-chips" role="tablist">
          <button class="chip active" data-filter="all" role="tab" aria-selected="true">All</button>
          {categories.map(([key, label]) => (
            <button class="chip" data-filter={key} role="tab" aria-selected="false">{label}</button>
          ))}
        </div>
      </div>

      <p class="results-count" id="results-count">
        Showing <strong>{mainResources.length}</strong> resources
      </p>

      <!-- Resource cards -->
      <div class="resource-list" id="resource-list">
        {mainResources.map(r => (
          <div
            class="resource-item"
            data-category={r.category}
            data-tags={r.tags.join(',')}
            data-search={`${r.title} ${r.author || ''} ${r.description}`.toLowerCase()}
          >
            <div class="resource-main">
              {r.url ? (
                <a href={r.url} target="_blank" rel="noopener noreferrer" class="resource-title">{r.title}</a>
              ) : (
                <span class="resource-title">{r.title}</span>
              )}
              {r.author && <span class="resource-author">by {r.author}</span>}
              {r.year && <span class="resource-year">({r.year})</span>}
              {r.phone && <span class="resource-phone">{r.phone}</span>}
            </div>
            <p class="resource-note">{r.description}</p>
            <div class="resource-tags">
              <span class="resource-cat-tag">{categoryLabels[r.category]}</span>
              {r.tags.map(tag => (
                <span class="resource-tag">{tag}</span>
              ))}
            </div>
          </div>
        ))}
      </div>

      <p class="no-results" id="no-results" style="display:none;">
        No resources match your search. Try a different term or <button class="reset-link" id="reset-filters">clear all filters</button>.
      </p>

      <!-- Professional Directory -->
      <div class="resource-section" id="professional-directory">
        <h2>Professional Directory</h2>
        <p style="color:var(--color-charcoal-mid);">
          A directory of therapists, lawyers, and coaches who understand parental alienation
          is coming soon. If you are a professional who works with alienated parents and would
          like to be included, <a href="/contact">get in touch</a>.
        </p>
      </div>

      <!-- CTA -->
      <div class="resource-cta">
        <p>Still looking for something?</p>
        <a href="/contact" class="btn btn-outline">Contact Malcolm &rarr;</a>
      </div>

    </div>
  </section>

</BaseLayout>

<script>
  const searchInput = document.getElementById('resource-search') as HTMLInputElement;
  const chips = document.querySelectorAll<HTMLButtonElement>('.chip');
  const items = document.querySelectorAll<HTMLElement>('.resource-item');
  const countEl = document.getElementById('results-count')!;
  const noResults = document.getElementById('no-results')!;
  const resetBtn = document.getElementById('reset-filters');

  let activeCategory = 'all';

  function applyFilters() {
    const query = searchInput.value.toLowerCase().trim();
    let visible = 0;

    items.forEach(item => {
      const cat = item.dataset.category || '';
      const searchText = item.dataset.search || '';

      const categoryMatch = activeCategory === 'all' || cat === activeCategory;
      const searchMatch = !query || searchText.includes(query);

      if (categoryMatch && searchMatch) {
        item.style.display = '';
        visible++;
      } else {
        item.style.display = 'none';
      }
    });

    countEl.innerHTML = `Showing <strong>${visible}</strong> resource${visible !== 1 ? 's' : ''}`;
    noResults.style.display = visible === 0 ? '' : 'none';

    // Update URL hash
    if (activeCategory !== 'all') {
      history.replaceState(null, '', `#${activeCategory}`);
    } else if (!query) {
      history.replaceState(null, '', window.location.pathname);
    }
  }

  chips.forEach(chip => {
    chip.addEventListener('click', () => {
      chips.forEach(c => { c.classList.remove('active'); c.setAttribute('aria-selected', 'false'); });
      chip.classList.add('active');
      chip.setAttribute('aria-selected', 'true');
      activeCategory = chip.dataset.filter || 'all';
      applyFilters();
    });
  });

  searchInput.addEventListener('input', applyFilters);

  resetBtn?.addEventListener('click', () => {
    searchInput.value = '';
    activeCategory = 'all';
    chips.forEach(c => { c.classList.remove('active'); c.setAttribute('aria-selected', 'false'); });
    chips[0]?.classList.add('active');
    chips[0]?.setAttribute('aria-selected', 'true');
    applyFilters();
  });

  // Read hash on load
  const hash = window.location.hash.replace('#', '');
  if (hash) {
    const target = document.querySelector<HTMLButtonElement>(`.chip[data-filter="${hash}"]`);
    if (target) {
      target.click();
    }
  }
</script>

<style>
.eyebrow {
  font-size: 0.78rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--color-amber);
  margin-bottom: 0.5rem;
}
.intro {
  font-size: 1.05rem;
  color: var(--color-charcoal-mid);
  margin-bottom: 2.5rem;
  line-height: 1.7;
}

/* ── Crisis banner ───────────────────────────── */
.crisis-banner {
  background: #fef3e1;
  border: 1px solid #e8c87a;
  border-radius: 12px;
  padding: 1.5rem 1.75rem;
  margin-bottom: 2.5rem;
}
.crisis-heading {
  font-size: 1rem;
  font-weight: 700;
  color: #9a5b13;
  margin-bottom: 1rem;
}
.crisis-items {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 1rem;
}
.crisis-item {
  background: #fff;
  border-radius: 8px;
  padding: 0.75rem 1rem;
}
.crisis-title {
  font-weight: 600;
  font-size: 0.88rem;
  color: var(--color-green-deep);
  text-decoration: none;
}
.crisis-title:hover { color: var(--color-amber); }
.crisis-phone {
  display: block;
  font-weight: 700;
  font-size: 0.95rem;
  color: #9a5b13;
  margin: 0.25rem 0;
}
.crisis-note {
  font-size: 0.8rem;
  color: var(--color-charcoal-mid);
  margin: 0;
  line-height: 1.5;
}

/* ── Search + filter bar ─────────────────────── */
.filter-bar {
  margin-bottom: 1.5rem;
}
.search-wrap {
  margin-bottom: 1rem;
}
.search-input {
  width: 100%;
  padding: 0.65rem 1rem;
  font-size: 0.92rem;
  border: 1px solid var(--color-border);
  border-radius: 8px;
  background: #fff;
  color: var(--color-charcoal);
  transition: border-color 0.15s;
}
.search-input:focus {
  outline: none;
  border-color: var(--color-green-deep);
  box-shadow: 0 0 0 2px rgba(12, 94, 93, 0.1);
}
.search-input::placeholder {
  color: var(--color-warm-grey);
}
.filter-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}
.chip {
  padding: 0.4rem 0.85rem;
  font-size: 0.82rem;
  font-weight: 500;
  border: 1px solid var(--color-border);
  border-radius: 999px;
  background: #fff;
  color: var(--color-charcoal-mid);
  cursor: pointer;
  transition: all 0.15s;
}
.chip:hover {
  border-color: var(--color-green-deep);
  color: var(--color-green-deep);
}
.chip.active {
  background: var(--color-green-deep);
  border-color: var(--color-green-deep);
  color: #fff;
  font-weight: 600;
}

.results-count {
  font-size: 0.85rem;
  color: var(--color-warm-grey);
  margin-bottom: 1.5rem;
}

/* ── Resource cards ──────────────────────────── */
.resource-list {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}
.resource-item {
  padding: 1.25rem;
  background: var(--color-ivory-alt);
  border: 1px solid var(--color-border);
  border-radius: 10px;
  transition: border-color 0.15s;
}
.resource-item:hover {
  border-color: var(--color-green-deep);
}
.resource-main {
  display: flex;
  flex-wrap: wrap;
  align-items: baseline;
  gap: 0.4rem;
  margin-bottom: 0.5rem;
}
.resource-title {
  font-weight: 600;
  color: var(--color-green-deep);
  font-size: 0.95rem;
  text-decoration: none;
}
a.resource-title:hover { color: var(--color-amber); }
.resource-author {
  font-size: 0.85rem;
  color: var(--color-warm-grey);
}
.resource-year {
  font-size: 0.82rem;
  color: var(--color-warm-grey);
}
.resource-phone {
  font-size: 0.85rem;
  font-weight: 600;
  color: #9a5b13;
}
.resource-note {
  font-size: 0.88rem;
  color: var(--color-charcoal-mid);
  margin: 0 0 0.75rem;
  line-height: 1.6;
}
.resource-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.35rem;
}
.resource-cat-tag {
  font-size: 0.7rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  padding: 0.15rem 0.5rem;
  border-radius: 4px;
  background: var(--color-green-deep);
  color: #fff;
}
.resource-tag {
  font-size: 0.7rem;
  padding: 0.15rem 0.45rem;
  border-radius: 4px;
  background: var(--color-ivory);
  border: 1px solid var(--color-border);
  color: var(--color-charcoal-mid);
}

/* ── No results ──────────────────────────────── */
.no-results {
  text-align: center;
  padding: 2rem;
  color: var(--color-charcoal-mid);
  font-size: 0.95rem;
}
.reset-link {
  background: none;
  border: none;
  color: var(--color-green-deep);
  font-weight: 600;
  cursor: pointer;
  text-decoration: underline;
  font-size: inherit;
  padding: 0;
}

/* ── Professional directory + CTA ────────────── */
.resource-section {
  margin-top: 3rem;
  margin-bottom: 2rem;
}
.resource-section h2 {
  font-size: 1.3rem;
  margin-bottom: 1rem;
  padding-bottom: 0.75rem;
  border-bottom: 2px solid var(--color-border);
}
.resource-cta {
  margin-top: 2rem;
  padding: 2rem;
  background: var(--color-ivory-alt);
  border: 1px solid var(--color-border);
  border-radius: 12px;
  text-align: center;
}
.resource-cta p {
  font-size: 1.05rem;
  font-weight: 600;
  color: var(--color-green-deep);
  margin-bottom: 1rem;
}
</style>
