  box-shadow: 0 4px 16px rgba(0,0,0,0.08);
}
.card-link {
  display: inline-block;
  margin-top: 0.75rem;
  font-size: 0.82rem;
  font-weight: 600;
  color: var(--color-green-deep);
  letter-spacing: 0.02em;
}

