.eyebrow {
  font-size: 0.78rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--color-amber-light);
  margin-bottom: 0.5rem;
}
.hero-intro {
  font-size: 1.1rem;
  color: rgba(248, 244, 239, 0.8);
  margin-top: 1.25rem;
  line-height: 1.75;
  max-width: 640px;
  margin-inline: auto;
}
.lead-text {
  font-size: 1.15rem;
  line-height: 1.75;
  color: var(--color-charcoal);
  margin-bottom: 1.5rem;
}
.dimension-label {
  font-family: var(--font-serif);
  font-style: italic;
  font-size: 1.05rem;
  color: var(--color-amber);
  margin-bottom: 0.15rem;
}
.dimension-subtitle {
  font-style: italic;
  color: var(--color-charcoal-mid);
  margin-top: -0.5rem;
  margin-bottom: 1rem;
}

