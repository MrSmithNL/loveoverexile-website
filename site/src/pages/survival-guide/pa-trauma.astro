.factor-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1.25rem;
  margin-block: 2rem;
}
.factor-card {
  padding: 1.5rem;
  position: relative;
}
.factor-letter {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: var(--color-amber);
  color: white;
  font-weight: 700;
  font-size: 0.8rem;
  margin-bottom: 0.6rem;
}
.factor-card h3 {
  font-size: 0.95rem;
