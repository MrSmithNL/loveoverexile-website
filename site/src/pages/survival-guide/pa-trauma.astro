  padding: 1.75rem;
  position: relative;
}
.wound-number {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: var(--color-green-deep);
  color: white;
  font-weight: 700;
  font-size: 0.85rem;
  margin-bottom: 0.75rem;
}
.wound-card h3 {
  font-size: 1.05rem;
  margin-bottom: 0.25rem;
  color: var(--color-green-deep);
}
.wound-tagline {
  font-style: italic;
  font-size: 0.85rem;
  color: var(--color-amber);
  margin-bottom: 0.75rem;
}
