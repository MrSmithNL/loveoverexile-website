---
import BaseLayout from '../layouts/BaseLayout.astro';

const faqLOE = [
  {
    q: 'What is Love Over Exile?',
    a: 'Love Over Exile is a book by Malcolm Smith about surviving parental alienation — and a platform built around it. The website brings together articles, community, and free resources for alienated parents.'
  },
  {
    q: 'When does the book come out?',
    a: 'The book is in its final stages and will launch soon. Join the waitlist at /the-book to be first to know — and to receive the free Survival Guide while you wait.'
  },
  {
    q: 'Is this a professional or clinical service?',
    a: 'No. Love Over Exile is a personal platform built by an alienated parent, for alienated parents. Nothing here is legal advice or clinical treatment. For professional support, see the Resources page.'
  },
  {
    q: 'Who runs the community forum?',
    a: 'Malcolm runs the community with AI-assisted moderation (clearly labelled). For serious or urgent matters, Malcolm is always involved. The AI assistant never handles crisis situations alone.'
  },
  {
    q: 'Is the community free?',
    a: 'Yes. The community is free to join. The Survival Guide is also free when you sign up.'
  },
  {
    q: 'How do I contact Malcolm?',
    a: 'Use the Contact page. Malcolm reads every message — response times vary, but nothing is ignored.'
  },
];

const faqPA = [
  {
    q: 'What is parental alienation?',
    a: 'Parental alienation is a pattern where one parent systematically damages and undermines a child\'s relationship with the other parent. It can range from mild negative commentary to complete psychological alienation — where the child refuses all contact with the target parent, often with no rational basis.'
  },
  {
    q: 'Is parental alienation recognised legally?',
    a: 'Recognition varies significantly by jurisdiction and court. In some family court systems it is well understood; in others it is dismissed or confused with legitimate abuse allegations. Having a clear, evidence-based account of the behaviour pattern is important in legal settings.'
  },
  {
    q: 'Can parental alienation happen to mothers as well as fathers?',
    a: 'Yes. Both mothers and fathers can be alienating parents, and both can be target parents. Research shows that fathers are statistically more often the target parent in high-conflict divorces, but this is not universal.'
  },
  {
    q: 'What can I do if my child refuses to see me?',
    a: 'The Survival Guide covers this in detail. In brief: maintain consistent, gentle communication; document everything; avoid negative commentary about the other parent; seek legal advice if contact orders are being breached; and prioritise your own mental health to stay in the long game.'
  },
  {
    q: 'Will my child eventually understand what happened?',
    a: 'Research by Amy Baker and others documents that many alienated children, as adults, come to understand and regret what happened. Maintaining a consistent, loving presence — even when rejected — significantly improves the chances of eventual reconnection. This is the core argument of Part III of Love Over Exile.'
  },
  {
    q: 'Is parental alienation the same as emotional abuse?',
    a: 'Many researchers and therapists classify severe parental alienation as a form of emotional abuse — of both the child and the target parent. It is included in some academic definitions of child psychological maltreatment. However, legal definitions and court responses vary widely.'
  },
];

// FAQPage structured data for rich snippets
const allFaqItems = [...faqLOE, ...faqPA];
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: allFaqItems.map(item => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.a,
    },
  })),
};
---

<BaseLayout
  title="FAQ"
  description="Frequently asked questions about Love Over Exile and about parental alienation — what it is, how it works, and what you can do."
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <section class="section">
    <div class="container-narrow">
      <h1>Frequently Asked Questions</h1>
      <p class="intro">
        Questions about this website and community, and about parental alienation itself.
      </p>

      <div class="faq-section">
        <h2>About Love Over Exile</h2>
        <dl class="faq-list">
          {faqLOE.map(item => (
            <div class="faq-item">
              <dt class="faq-q">{item.q}</dt>
              <dd class="faq-a">{item.a}</dd>
            </div>
          ))}
        </dl>
      </div>

      <hr class="divider" />

      <div class="faq-section">
        <h2>About Parental Alienation</h2>
        <dl class="faq-list">
          {faqPA.map(item => (
            <div class="faq-item">
              <dt class="faq-q">{item.q}</dt>
              <dd class="faq-a">{item.a}</dd>
            </div>
          ))}
        </dl>
      </div>

      <div class="faq-cta">
        <p>Still have a question?</p>
        <a href="/contact" class="btn btn-outline">Contact Malcolm →</a>
      </div>

    </div>
  </section>

</BaseLayout>

<style>
.intro {
  font-size: 1.05rem;
  color: var(--color-charcoal-mid);
  margin-bottom: 3rem;
}
.faq-section { margin-bottom: 2rem; }
.faq-section h2 { margin-bottom: 1.5rem; }

.faq-list {
  display: flex;
  flex-direction: column;
  gap: 0;
}
.faq-item {
  border-bottom: 1px solid var(--color-border);
  padding-block: 1.5rem;
}
.faq-item:first-child { border-top: 1px solid var(--color-border); }

.faq-q {
  font-family: var(--font-serif);
  font-size: 1.05rem;
  font-weight: 600;
  color: var(--color-green-deep);
  margin-bottom: 0.75rem;
  line-height: 1.35;
}
.faq-a {
  font-size: 0.95rem;
  color: var(--color-charcoal-mid);
  line-height: 1.75;
  margin: 0;
}

.faq-cta {
  margin-top: 3rem;
  padding: 2rem;
  background: var(--color-ivory-alt);
  border: 1px solid var(--color-border);
  border-radius: 12px;
  text-align: center;
}
.faq-cta p {
  font-size: 1.05rem;
  font-weight: 600;
  color: var(--color-green-deep);
  margin-bottom: 1rem;
}
</style>
